{
  "name": "visual-cursor",
  "version": "0.1.0",
  "description": "⌘-click any React component in the browser, describe a change in plain English, and a local Cursor agent edits the source file live via HMR.",
  "type": "module",
  "license": "MIT",
  "author": "tjcages",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tjcages/visual-cursor.git"
  },
  "bugs": {
    "url": "https://github.com/tjcages/visual-cursor/issues"
  },
  "homepage": "https://github.com/tjcages/visual-cursor#readme",
  "sideEffects": false,
  "keywords": [
    "vite",
    "vite-plugin",
    "react",
    "cursor",
    "agent",
    "devtools",
    "hmr",
    "click-to-source"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@cursor/sdk": ">=1.0.22",
    "react": ">=18",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@cursor/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.24.0"
  },
  "devDependencies": {
    "@babel/types": "^7.24.0",
    "@cursor/sdk": "^1.0.22",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^20.0.0",
    "@types/react": ">=18",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "react": ">=18",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0"
}
